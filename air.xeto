//////////////////////////////////////////////////////////////////////////
// Weather/Outside Air Conditions
//////////////////////////////////////////////////////////////////////////

+WeatherWetbulbPoint {
  hisMode: "sampled"
  hisCollectInterval: "5min"
  navName: "OaWetBulb"
}

+WeatherDewPointPoint {
  hisMode: "sampled"
  hisCollectInterval: "5min"
  navName: "OaDewPt"
}

//////////////////////////////////////////////////////////////////////////
// Freeze Protection
//////////////////////////////////////////////////////////////////////////

+FreezeStatSensor {
  hisMode: "cov"
  hisCollectInterval: "24hr"
  navName: "FrzStat"
}

//////////////////////////////////////////////////////////////////////////
// Filter Points
//////////////////////////////////////////////////////////////////////////

+FilterSensor {
  hisMode: "cov"
  hisCollectInterval: "24hr"
  navName: "FiltSts"
}

// Filter pressure differential sensor
pbsFilterPressureDeltaSensor: FilterPressureSensor {
  hisMode: "sampled"
  hisCollectInterval: "10min"
  delta
  navName: "FiltDiffPress"
}

// Pre-filter pressure differential sensor
PreFilterPressureDeltaSensor: FilterPressureSensor {
  hisMode: "sampled"
  hisCollectInterval: "10min"
  pre
  delta
  navName: "PreFiltDiffPress"
}

// Final filter pressure differential sensor
FinalFilterPressureDeltaSensor: FilterPressureSensor {
  hisMode: "sampled"
  hisCollectInterval: "10min"
  final
  delta
  navName: "FinalFiltDiffPress"
}

//////////////////////////////////////////////////////////////////////////
// Dehumidification Points
//////////////////////////////////////////////////////////////////////////

// Return air dehumidification setpoint
ReturnAirDehumidSp: AirHumiditySp {
  hisMode: "cov"
  hisCollectInterval: "24hr"
  return
  navName: "RaDehumSp"
}

