+ZoneCo2Sensor {
  hisMode: "sampled"
  hisCollectInterval: "10min"
  navName: "ZnCo2"
}

+ZoneCo2Sp {
  hisMode: "cov"
  hisCollectInterval: "24hr"
  navName: "ZnCo2Sp"
